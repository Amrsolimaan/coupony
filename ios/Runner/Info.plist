<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<!-- ════════════════════════════════════════════════════════ -->
		<!-- BASIC APP CONFIGURATION -->
		<!-- ════════════════════════════════════════════════════════ -->
		<key>CFBundleDevelopmentRegion</key>
		<string>$(DEVELOPMENT_LANGUAGE)</string>
		<key>CFBundleDisplayName</key>
		<string>Coupony</string>
		<key>CFBundleExecutable</key>
		<string>$(EXECUTABLE_NAME)</string>
		<key>CFBundleIdentifier</key>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
		<key>CFBundleInfoDictionaryVersion</key>
		<string>6.0</string>
		<key>CFBundleName</key>
		<string>coupon</string>
		<key>CFBundlePackageType</key>
		<string>APPL</string>
		<key>CFBundleShortVersionString</key>
		<string>$(FLUTTER_BUILD_NAME)</string>
		<key>CFBundleSignature</key>
		<string>????</string>
		<key>CFBundleVersion</key>
		<string>$(FLUTTER_BUILD_NUMBER)</string>
		<key>LSRequiresIPhoneOS</key>
		
		<true/>
		<!-- ════════════════════════════════════════════════════════ -->
		<!-- LOCALIZATION SUPPORT (AR/EN) -->
		<!-- ════════════════════════════════════════════════════════ -->
		<!-- Supported localizations - App will switch based on device language or user preference -->
		<key>CFBundleLocalizations</key>
		<array>
			<string>ar</string>
			<string>en</string>
		</array>
		<!-- ════════════════════════════════════════════════════════ -->
		<!-- LOCATION PERMISSION (iOS 11+) -->
		<!-- ════════════════════════════════════════════════════════ -->
		<!-- 
		IMPORTANT: 
		- iOS will automatically show the correct language based on:
		  1. Device language setting
		  2. App's current locale (from LocaleCubit)
		- To support both AR/EN properly, create InfoPlist.strings files:
		  * ios/Runner/ar.lproj/InfoPlist.strings
		  * ios/Runner/en.lproj/InfoPlist.strings
		- For now, this English text will be shown (default)
		- iOS will use localized version if InfoPlist.strings exists
	-->
		<!-- Default English (fallback if no localized string found) -->
		<key>NSLocationWhenInUseUsageDescription</key>
		<string>نحتاج للوصول إلى موقعك لعرض المتاجر والعروض القريبة منك</string>
		<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
		<string>نحتاج للوصول إلى موقعك لتزويدك بأفضل العروض حتى عند تشغيل التطبيق في الخلفية</string>
		<key>NSLocationAlwaysUsageDescription</key>
		<string>نحتاج للوصول إلى موقعك لتزويدك بأفضل العروض حتى عند تشغيل التطبيق في الخلفية</string>
		<!-- ════════════════════════════════════════════════════════ -->
		<!-- NOTIFICATION PERMISSION (iOS 10+) -->
		<!-- ════════════════════════════════════════════════════════ -->
	
		<!-- ════════════════════════════════════════════════════════ -->
		<!-- Microphone PERMISSION (iOS 10+) -->
		<!-- ════════════════════════════════════════════════════════ -->
	
		<key>NSMicrophoneUsageDescription</key>
		<string>للبحث الصوتي</string>
		<!-- Enable background modes for notifications -->
		<key>UIBackgroundModes</key>
		<array>
			<string>remote-notification</string>
			<string>location</string>
		</array>
		<!-- ════════════════════════════════════════════════════════ -->
		<!-- UI CONFIGURATION -->
		<!-- ════════════════════════════════════════════════════════ -->
		<key>UILaunchStoryboardName</key>
		<string>LaunchScreen</string>
		<key>UIMainStoryboardFile</key>
		<string>Main</string>
		<!-- Supported orientations for iPhone -->
		<key>UISupportedInterfaceOrientations</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<!-- Supported orientations for iPad -->
		<key>UISupportedInterfaceOrientations~ipad</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationPortraitUpsideDown</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<!-- ════════════════════════════════════════════════════════ -->
		<!-- PERFORMANCE & DISPLAY -->
		<!-- ════════════════════════════════════════════════════════ -->
		<key>CADisableMinimumFrameDurationOnPhone</key>
		<true/>
		<key>UIApplicationSupportsIndirectInputEvents</key>
		<true/>
		<key>UIStatusBarHidden</key>
		<false/>
		<key>UIViewControllerBasedStatusBarAppearance</key>
		<false/>
	</dict>
</plist>
